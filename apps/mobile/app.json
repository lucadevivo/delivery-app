{
  "expo": {
    "name": "Rider",
    "slug": "rider",
    "scheme": "rider",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rider.mobile"
    },
    "android": {
      "package": "app.rider.mobile"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "extra": {
      "apiUrl": "http://localhost:4000"
    }
  }
}
