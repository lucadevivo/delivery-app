# --- Produzione: copiare in .env accanto a docker-compose.prod.yml ---

# Postgres (gestito esternamente o dal servizio db del compose)
POSTGRES_DB=rider_db
POSTGRES_USER=rider
POSTGRES_PASSWORD=usa-una-password-forte
# Se usi il db del compose, l'host è "db"; se gestito, metti l'host del provider.
DATABASE_URL=postgresql://rider:usa-una-password-forte@db:5432/rider_db

# Better Auth — genera il secret con: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.tuo-dominio.app

# Verifica email obbligatoria in produzione
REQUIRE_EMAIL_VERIFICATION=true

# SMTP per email transazionali (verifica + reset password)
SMTP_URL=smtp://utente:password@smtp.provider.com:587
SMTP_FROM=no-reply@tuo-dominio.app
